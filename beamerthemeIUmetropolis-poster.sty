%%
%% IU-Metropolis Poster Theme
%% Based on beamerposter and IUmetropolis theme
%% For academic conference posters with Indiana University branding
%% Created: 2025-11-30
%%

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeIUmetropolis-poster}[2025/11/30 IU Metropolis Poster Theme]

% Load beamerposter package for poster support
\RequirePackage{beamerposter}

% Load base IU-Metropolis theme (inherits all colors, fonts, blocks)
\usetheme{IUmetropolis}

% Additional packages for poster layout
\RequirePackage{tikz}
\RequirePackage{adjustbox}
\RequirePackage{multicol}
\RequirePackage{qrcode}

%-------------------------------------------------------------------------------
% POSTER-SPECIFIC METROPOLIS OPTIONS
%-------------------------------------------------------------------------------

% Override Metropolis settings for posters
\metroset{
    titleformat=regular,           % Regular title format
    progressbar=none,              % No progress bar on posters
    numbering=none,                % No slide numbers
    block=fill,                    % Filled blocks
}

%-------------------------------------------------------------------------------
% POSTER DIMENSIONS & SCALING
%-------------------------------------------------------------------------------

% Default poster size: A0 portrait (can be overridden in document)
% Standard sizes:
% - A0: width=841mm, height=1189mm (33.1" x 46.8")
% - A1: width=594mm, height=841mm  (23.4" x 33.1")
% - Custom: specify in document preamble

%-------------------------------------------------------------------------------
% POSTER LAYOUT SPACING
%-------------------------------------------------------------------------------

% Increase spacing for better readability at poster scale
\setlength{\leftmargini}{2em}
\setlength{\leftmarginii}{1.5em}
\setlength{\leftmarginiii}{1.2em}

% Poster margins are initialized below after the margin registers are defined.

%-------------------------------------------------------------------------------
% POSTER HEADLINE (HEADER BANNER)
%-------------------------------------------------------------------------------

% Define poster metadata commands
\newcommand{\posterauthors}[1]{\def\@posterauthors{#1}}
\newcommand{\posteraffiliation}[1]{\def\@posteraffiliation{#1}}
\newcommand{\posteremail}[1]{\def\@posteremail{#1}}
\newcommand{\posterlogo}[1]{\def\@posterlogo{#1}}
\newcommand{\posterfooterlogo}[1]{\def\@posterfooterlogo{#1}}
\newcommand{\posterheadline}[1]{\def\@posterheadline{#1}}
\newcommand{\posterqrurl}[1]{\def\@posterqrurl{#1}}
\newcommand{\posterqrlabel}[1]{\def\@posterqrlabel{#1}}
\newcommand{\posterqrheight}[1]{\def\@posterqrheight{#1}}
\newcommand{\posterqrwidth}[1]{\def\@posterqrwidth{#1}}
\newcommand{\posterheadertextwidth}[1]{\def\@posterheadertextwidth{#1}}
\newlength{\poster@headermargin}
\newlength{\poster@bodymargin}
\newlength{\poster@bottommargin}
\newlength{\poster@blockpadding}
\newlength{\poster@accentheight}
\newlength{\poster@columncontentwidth}
\newlength{\poster@figurewidth}
\newcommand{\poster@headerinnerwidth}{\dimexpr\paperwidth-2\poster@headermargin\relax}
\newcommand{\posterheadermargin}[1]{%
  \setlength{\poster@headermargin}{#1}%
  \setlength{\poster@accentheight}{\dimexpr#1/4\relax}%
}
\newcommand{\posterbodymargin}[1]{%
  \setlength{\poster@bodymargin}{#1}%
  \setlength{\poster@blockpadding}{\dimexpr3\poster@bodymargin/4\relax}%
  \setbeamersize{text margin left=\poster@bodymargin, text margin right=\poster@bodymargin}%
}
\newcommand{\postermargin}[1]{%
  \posterheadermargin{#1}%
  \posterbodymargin{#1}%
  \setlength{\poster@bottommargin}{#1}%
}
\newcommand{\posterbottommargin}[1]{\setlength{\poster@bottommargin}{#1}}
\newcommand{\postermargins}[3]{%
  \posterheadermargin{#1}%
  \posterbodymargin{#2}%
  \posterbottommargin{#3}%
}
\newcommand{\postergutter}{\poster@bodymargin}

% Initialize defaults
\def\@posterauthors{}
\def\@posteraffiliation{Indiana University}
\def\@posteremail{}
\def\@posterlogo{}
\def\@posterfooterlogo{}
\def\@posterheadline{}
\def\@posterqrurl{}
\def\@posterqrlabel{}
\def\@posterqrheight{6cm}
\def\@posterqrwidth{6cm}
\def\@posterheadertextwidth{0.9\linewidth}
\postermargin{2cm}

% Poster frames should use fixed body gutters. Beamer's default [t] frame top
% skip includes stretch, which makes the gap below the headline unpredictable.
\define@key{beamerframe}{t}[true]{%
  \beamer@frametopskip=0pt\relax%
  \beamer@framebottomskip=0pt plus 1fill\relax%
  \beamer@frametopskipautobreak=\beamer@frametopskip\relax%
  \beamer@framebottomskipautobreak=\beamer@framebottomskip\relax%
}

\newcommand{\@posterheaderbox}[2]{%
  \parbox{\@posterheadertextwidth}{\centering\usebeamerfont{#1}#2}%
}

\newcommand{\@postermaintitle}[1]{%
  \@posterheaderbox{poster headline}{\color{IUCream}#1}%
  \vskip\dimexpr3\poster@headermargin/4\relax
}

\newcommand{\@posterresearchtitle}{\color{IULightCream}\inserttitle}

\newcommand{\@posterqrcode}{%
  \begingroup
  \usebeamercolor[fg]{headline}%
  \begin{minipage}[b]{\@posterqrwidth}
    \centering
    \qrcode[height=\@posterqrheight]{\@posterqrurl}\\[\dimexpr\postergutter/10\relax]
    \ifx\@posterqrlabel\@empty\else
      {\usebeamerfont{poster qr label}\@posterqrlabel}
    \fi
  \end{minipage}%
  \endgroup
}

\newcommand{\@posterheadercontent}{%
  \begingroup
  \centering
    \ifx\@posterlogo\@empty\else
      \@posterlogo
      \par\vskip\dimexpr\poster@headermargin/4\relax
    \fi

    \ifx\@posterheadline\@empty
      \@postermaintitle{\inserttitle}
    \else
      \@postermaintitle{\@posterheadline}
    \fi

    % Authors and formal paper title share the title text width.
    \ifx\@posterauthors\@empty
      \ifx\@posterheadline\@empty\else
        \@posterheaderbox{poster author}{\@posterresearchtitle}%
        \vskip\dimexpr\postergutter/4\relax
      \fi
    \else
      \@posterheaderbox{poster author}{%
        {\color{IUCream}\@posterauthors}%
        \ifx\@posterheadline\@empty\else\\[\dimexpr3\postergutter/20\relax]\@posterresearchtitle\fi}%
      \vskip\dimexpr\postergutter/4\relax
    \fi

    % Affiliation
    \ifx\@posteraffiliation\@empty\else
      {\usebeamerfont{poster affiliation}\color{IULightCream}\@posteraffiliation}
    \fi

    % Email
    \ifx\@posteremail\@empty\else
      \vskip\dimexpr\postergutter/4\relax
      {\usebeamerfont{poster email}\color{IULightCream}\texttt{\@posteremail}}
    \fi
  \par
  \endgroup
}

% Headline template - compact full-width crimson banner with white text.
% If \posterheadline is set, use it as the large takeaway and place the formal
% paper title after the authors.
\setbeamertemplate{headline}{
  \begin{beamercolorbox}[wd=\paperwidth, sep=0pt, vmode]{headline}
    \vskip\poster@headermargin
    \noindent\hbox to\paperwidth{%
      \hskip\poster@headermargin
      \begin{minipage}{\poster@headerinnerwidth}
        \@posterheadercontent
        \ifx\@posterqrurl\@empty\else
          \par\nointerlineskip
          \noindent\makebox[\linewidth][r]{\smash{\@posterqrcode}}%
        \fi
      \end{minipage}%
      \hskip\poster@headermargin
    }%
    \vskip\poster@headermargin
  \end{beamercolorbox}

  % Light crimson accent stripe at bottom of header
  \begin{beamercolorbox}[wd=\paperwidth, ht=\poster@accentheight, sep=0pt, vmode]{headline accent}
  \end{beamercolorbox}
  \vskip\poster@bodymargin
}

%-------------------------------------------------------------------------------
% POSTER FOOTLINE (OPTIONAL FOOTER)
%-------------------------------------------------------------------------------

% Footer template - displays optional logo at bottom center
% Logo height automatically defines the content margin
\setbeamertemplate{footline}{
  \begin{beamercolorbox}[wd=\paperwidth, center]{footline}
    \vskip\poster@bottommargin
    \ifx\@posterfooterlogo\@empty\else
      \@posterfooterlogo
      \vskip\poster@bottommargin
    \fi
  \end{beamercolorbox}
}

%-------------------------------------------------------------------------------
% POSTER-SPECIFIC FONT SIZES
%-------------------------------------------------------------------------------

% Larger font sizes for poster readability (scale with poster size)
% These work well for A0 at default scale

% Header typography
\setbeamerfont{poster headline}{size=\fontsize{82}{96}\selectfont, series=\bfseries}
\setbeamerfont{poster author}{size=\fontsize{48}{57}\selectfont}
\setbeamerfont{poster affiliation}{size=\fontsize{32}{38}\selectfont}
\setbeamerfont{poster email}{size=\fontsize{28}{34}\selectfont}
\setbeamerfont{poster qr label}{size=\fontsize{18}{22}\selectfont}

% Standard title metadata fonts mirror the poster header defaults.
\setbeamerfont{title}{parent=poster headline}
\setbeamerfont{author}{parent=poster author}
\setbeamerfont{institute}{parent=poster affiliation}
\setbeamerfont{email}{parent=poster email}

% Frame title (section headers in poster)
\setbeamerfont{frametitle}{size=\fontsize{64}{76}\selectfont, series=\bfseries}

% Block titles (regular, alert, example)
\setbeamerfont{block title}{size=\fontsize{48}{58}\selectfont, series=\bfseries}
\setbeamerfont{block title alerted}{size=\fontsize{48}{58}\selectfont, series=\bfseries}
\setbeamerfont{block title example}{size=\fontsize{48}{58}\selectfont, series=\bfseries}

% Block body text (regular, alert, example)
\setbeamerfont{block body}{size=\fontsize{36}{43}\selectfont}
\setbeamerfont{block body alerted}{size=\fontsize{36}{43}\selectfont}
\setbeamerfont{block body example}{size=\fontsize{36}{43}\selectfont}

% Normal text (default body)
\setbeamerfont{normal text}{size=\fontsize{36}{43}\selectfont}

% Item labels (bullets)
\setbeamerfont{itemize/enumerate body}{size=\fontsize{36}{43}\selectfont}
\setbeamerfont{itemize/enumerate subbody}{size=\fontsize{32}{38}\selectfont}
\setbeamerfont{itemize/enumerate subsubbody}{size=\fontsize{28}{34}\selectfont}

% Caption text
\setbeamerfont{caption}{size=\fontsize{30}{36}\selectfont}
\setbeamerfont{caption name}{size=\fontsize{30}{36}\selectfont, series=\bfseries}

%-------------------------------------------------------------------------------
% POSTER-SPECIFIC COLORS
%-------------------------------------------------------------------------------

% Headline colors
\setbeamercolor{headline}{fg=IUCream, bg=IUDarkestCrimson}
\setbeamercolor{headline accent}{fg=white, bg=IULightCrimson}

% Ensure background is light cream (or can be overridden to white)
\setbeamercolor{background canvas}{bg=IULightCream}

% Optional: Override to pure white if preferred
% \setbeamercolor{background canvas}{bg=white}

%-------------------------------------------------------------------------------
% POSTER BLOCK CUSTOMIZATION
%-------------------------------------------------------------------------------

% Increase block spacing for posters
\newcommand{\poster@blockbegin}[2]{%
  \begin{beamercolorbox}[rounded=false, shadow=false, leftskip=\poster@blockpadding, rightskip=\poster@blockpadding, sep=\poster@blockpadding]{#1}
    \usebeamerfont*{#1}\insertblocktitle
  \end{beamercolorbox}
  \nointerlineskip
  \usebeamerfont{#2}
  \begin{beamercolorbox}[rounded=false, shadow=false, leftskip=\poster@blockpadding, rightskip=\poster@blockpadding, sep=\poster@blockpadding, vmode]{#2}
}

\newcommand{\poster@blockend}{%
  \end{beamercolorbox}
  \vskip\postergutter
}

\setbeamertemplate{block begin}{\poster@blockbegin{block title}{block body}}
\setbeamertemplate{block end}{\poster@blockend}

% Alert block
\setbeamertemplate{block alerted begin}{\poster@blockbegin{block title alerted}{block body alerted}}
\setbeamertemplate{block alerted end}{\poster@blockend}

% Example block
\setbeamertemplate{block example begin}{\poster@blockbegin{block title example}{block body example}}
\setbeamertemplate{block example end}{\poster@blockend}

%-------------------------------------------------------------------------------
% ITEMIZE/ENUMERATE CUSTOMIZATION FOR POSTERS
%-------------------------------------------------------------------------------

% Larger bullet points
\setbeamertemplate{itemize item}{\color{IUCrimson}\raisebox{0.2ex}{\scalebox{1.8}{$\bullet$}}}
\setbeamertemplate{itemize subitem}{\color{IUDarkCrimson}\raisebox{0.2ex}{\scalebox{1.5}{$\circ$}}}
\setbeamertemplate{itemize subsubitem}{\color{IUDarkCrimson}\raisebox{0.2ex}{\scalebox{1.2}{$-$}}}

%-------------------------------------------------------------------------------
% HELPER COMMANDS FOR POSTER LAYOUT
%-------------------------------------------------------------------------------

% Command to create a section header (not a block, just styled text)
\newcommand{\postersection}[1]{%
  \vskip\dimexpr\postergutter/2\relax
  {\usebeamerfont{frametitle}\color{IUCrimson}\textbf{#1}}
  \vskip\dimexpr\postergutter/4\relax
  {\color{IULightCrimson}\rule{\linewidth}{\dimexpr3\postergutter/20\relax}}
  \vskip\dimexpr\postergutter/4\relax
}

% Compatibility wrapper for the original postercolumns API.
\newenvironment{postercolumns}[1][T]{%
  \begin{columns}[#1]
}{%
  \end{columns}
}

% Grid helpers with fixed gutters matching \postergutter. The optional
% postergrid argument is the column count used to reserve gutter space.
\newif\ifposter@firstcolumn
\newenvironment{postergrid}[1][3]{%
  \par\nointerlineskip\noindent
  \setlength{\poster@columncontentwidth}{%
    \dimexpr\linewidth-\dimexpr\numexpr#1-1\relax\postergutter\relax\relax}%
  \poster@firstcolumntrue
  \hbox\bgroup\ignorespaces
}{%
  \unskip\egroup
  \par\ignorespacesafterend
}

\newenvironment{postergridcolumn}[2][t]{%
  \ifposter@firstcolumn
    \global\poster@firstcolumnfalse
  \else
    \hspace{\postergutter}%
  \fi
  \begin{minipage}[#1]{\dimexpr#2\poster@columncontentwidth\relax}%
  \raggedright\ignorespaces
}{%
  \end{minipage}%
  \ignorespacesafterend
}

% Command for figure with caption
\newcommand{\posterfigure}[3][1.0]{%
  \par
  \begingroup
    \setlength{\poster@figurewidth}{\dimexpr\linewidth-2\poster@blockpadding\relax}%
    \ifdim\poster@figurewidth<1pt
      \setlength{\poster@figurewidth}{\linewidth}%
    \fi
    \centering
    \includegraphics[width=#1\poster@figurewidth]{#2}%
    \par\vskip\dimexpr\postergutter/4\relax
    \parbox{\poster@figurewidth}{\centering\usebeamerfont{caption}\color{IUBlack}#3}%
    \par
  \endgroup
}

