%%
%% IU-Metropolis Poster Theme
%% Based on beamerposter and IUmetropolis theme
%% For academic conference posters with Indiana University branding
%% Created: 2025-11-30
%%

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeIUmetropolis-poster}[2025/11/30 IU Metropolis Poster Theme]

% Load beamerposter package for poster support
\RequirePackage{beamerposter}

% Load base IU-Metropolis theme (inherits all colors, fonts, blocks)
\usetheme{IUmetropolis}

% Additional packages for poster layout
\RequirePackage{tikz}
\RequirePackage{adjustbox}
\RequirePackage{multicol}
\RequirePackage{qrcode}
\RequirePackage{xparse}

%-------------------------------------------------------------------------------
% POSTER-SPECIFIC METROPOLIS OPTIONS
%-------------------------------------------------------------------------------

% Override Metropolis settings for posters
\metroset{
    titleformat=regular,           % Regular title format
    progressbar=none,              % No progress bar on posters
    numbering=none,                % No slide numbers
    block=fill,                    % Filled blocks
}

%-------------------------------------------------------------------------------
% POSTER DIMENSIONS & SCALING
%-------------------------------------------------------------------------------

% Default poster size: A0 portrait (can be overridden in document)
% Standard sizes:
% - A0: width=841mm, height=1189mm (33.1" x 46.8")
% - A1: width=594mm, height=841mm  (23.4" x 33.1")
% - Custom: specify in document preamble

%-------------------------------------------------------------------------------
% POSTER LAYOUT SPACING
%-------------------------------------------------------------------------------

% Increase spacing for better readability at poster scale
\setlength{\leftmargini}{2em}
\setlength{\leftmarginii}{1.5em}
\setlength{\leftmarginiii}{1.2em}

% Poster margins are initialized below after the margin registers are defined.

%-------------------------------------------------------------------------------
% POSTER HEADLINE (HEADER BANNER)
%-------------------------------------------------------------------------------

% Define poster metadata commands
\newcommand{\posterauthors}[1]{\def\@posterauthors{#1}}
\newcommand{\posteraffiliation}[1]{\def\@posteraffiliation{#1}}
\newcommand{\posteremail}[1]{\def\@posteremail{#1}}
\newcommand{\posterlogo}[1]{\def\@posterlogo{#1}}
\newcommand{\posterfooterlogo}[1]{\def\@posterfooterlogo{#1}}
\newcommand{\posterheadline}[1]{\def\@posterheadline{#1}}
\newcommand{\posterqrurl}[1]{\def\@posterqrurl{#1}}
\newcommand{\posterqrlabel}[1]{\def\@posterqrlabel{#1}}
\newcommand{\posterqrheight}[1]{\def\@posterqrheight{#1}}
\newcommand{\posterqrwidth}[1]{\def\@posterqrwidth{#1}}
\newcommand{\posterheadertextwidth}[1]{\def\@posterheadertextwidth{#1}}
\newlength{\poster@headermargin}
\newlength{\poster@headerbottommargin}
\newlength{\poster@bodymargin}
\newlength{\poster@bottommargin}
\newlength{\poster@blockmargin}
\newlength{\poster@blockpadding}
\newlength{\poster@accentheight}
\newlength{\poster@columncontentwidth}
\newlength{\poster@figurewidth}
\newlength{\poster@cellwidth}
\newlength{\poster@cellheight}
\newlength{\poster@fillblockbodyheight}
\newlength{\poster@fillblockcontentheight}
\newbox\poster@fillblocktitlebox
\newbox\poster@fillblockbodybox
\newif\ifposter@inlayoutcell
\newcommand{\posterlayoutheight}{\textheight}
\newcommand{\poster@headerinnerwidth}{\dimexpr\paperwidth-2\poster@headermargin\relax}
\newcommand{\posterheadermargin}[1]{%
  \setlength{\poster@headermargin}{#1}%
  \setlength{\poster@headerbottommargin}{\dimexpr3\poster@headermargin/4\relax}%
  \setlength{\poster@accentheight}{\dimexpr#1/4\relax}%
}
\newcommand{\posterheaderbottommargin}[1]{\setlength{\poster@headerbottommargin}{#1}}
\newcommand{\posterbodymargin}[1]{%
  \setlength{\poster@bodymargin}{#1}%
  \setlength{\poster@blockpadding}{\dimexpr3\poster@bodymargin/4\relax}%
  \setbeamersize{text margin left=\poster@bodymargin, text margin right=\poster@bodymargin}%
}
\newcommand{\postermargin}[1]{%
  \posterheadermargin{#1}%
  \posterbodymargin{#1}%
  \setlength{\poster@bottommargin}{#1}%
}
\newcommand{\posterbottommargin}[1]{\setlength{\poster@bottommargin}{#1}}
\newcommand{\posterblockmargin}[1]{\setlength{\poster@blockmargin}{#1}}
\newcommand{\postermargins}[3]{%
  \posterheadermargin{#1}%
  \posterbodymargin{#2}%
  \posterbottommargin{#3}%
}
\newcommand{\postergutter}{\poster@bodymargin}

% Initialize defaults
\def\@posterauthors{}
\def\@posteraffiliation{Indiana University}
\def\@posteremail{}
\def\@posterlogo{}
\def\@posterfooterlogo{}
\def\@posterheadline{}
\def\@posterqrurl{}
\def\@posterqrlabel{}
\def\@posterqrheight{6cm}
\def\@posterqrwidth{6cm}
\def\@posterheadertextwidth{0.9\linewidth}
\postermargin{2cm}
\posterblockmargin{\dimexpr\postergutter/4\relax}

% Poster frames should use fixed body gutters. Beamer's default [t] frame top
% skip includes stretch, which makes the gap below the headline unpredictable.
\define@key{beamerframe}{t}[true]{%
  \beamer@frametopskip=0pt\relax%
  \beamer@framebottomskip=0pt plus 1fill\relax%
  \beamer@frametopskipautobreak=\beamer@frametopskip\relax%
  \beamer@framebottomskipautobreak=\beamer@framebottomskip\relax%
}

\newcommand{\@posterheaderbox}[2]{%
  \parbox{\@posterheadertextwidth}{\centering\usebeamerfont{#1}#2}%
}

\newcommand{\@postermaintitle}[1]{%
  \@posterheaderbox{poster headline}{\color{IUCream}#1}%
  \vskip\dimexpr3\poster@headermargin/4\relax
}

\newcommand{\@posterresearchtitle}{\color{IULightCream}\inserttitle}

\newcommand{\@posterqrcode}{%
  \begingroup
  \usebeamercolor[fg]{headline}%
  \begin{minipage}[b]{\@posterqrwidth}
    \centering
    \qrcode[height=\@posterqrheight]{\@posterqrurl}\\[\dimexpr\postergutter/10\relax]
    \ifx\@posterqrlabel\@empty\else
      {\usebeamerfont{poster qr label}\@posterqrlabel}
    \fi
  \end{minipage}%
  \endgroup
}

\newcommand{\@posterheadercontent}{%
  \begingroup
  \centering
    \ifx\@posterlogo\@empty\else
      \@posterlogo
      \par\vskip\dimexpr\poster@headermargin/4\relax
    \fi

    \ifx\@posterheadline\@empty
      \@postermaintitle{\inserttitle}
    \else
      \@postermaintitle{\@posterheadline}
    \fi

    % Authors and formal paper title share the title text width.
    \ifx\@posterauthors\@empty
      \ifx\@posterheadline\@empty\else
        \@posterheaderbox{poster author}{\@posterresearchtitle}%
        \vskip\dimexpr\postergutter/4\relax
      \fi
    \else
      \@posterheaderbox{poster author}{%
        {\color{IUCream}\@posterauthors}%
        \ifx\@posterheadline\@empty\else\\[\dimexpr3\postergutter/20\relax]\@posterresearchtitle\fi}%
      \vskip\dimexpr\postergutter/4\relax
    \fi

    % Affiliation
    \ifx\@posteraffiliation\@empty\else
      {\usebeamerfont{poster affiliation}\color{IULightCream}\@posteraffiliation}
    \fi

    % Email
    \ifx\@posteremail\@empty\else
      \vskip\dimexpr\postergutter/4\relax
      {\usebeamerfont{poster email}\color{IULightCream}\texttt{\@posteremail}}
    \fi
  \par
  \endgroup
}

% Headline template - compact full-width crimson banner with white text.
% If \posterheadline is set, use it as the large takeaway and place the formal
% paper title after the authors.
\setbeamertemplate{headline}{
  \begin{beamercolorbox}[wd=\paperwidth, sep=0pt, vmode]{headline}
    \vskip\poster@headermargin
    \noindent\hbox to\paperwidth{%
      \hskip\poster@headermargin
      \begin{minipage}{\poster@headerinnerwidth}
        \@posterheadercontent
        \ifx\@posterqrurl\@empty\else
          \par\nointerlineskip
          \noindent\makebox[\linewidth][r]{\smash{\@posterqrcode}}%
        \fi
      \end{minipage}%
      \hskip\poster@headermargin
    }%
    \vskip\poster@headerbottommargin
  \end{beamercolorbox}

  % Light crimson accent stripe at bottom of header
  \begin{beamercolorbox}[wd=\paperwidth, ht=\poster@accentheight, sep=0pt, vmode]{headline accent}
  \end{beamercolorbox}
  \vskip\poster@bodymargin
}

%-------------------------------------------------------------------------------
% POSTER FOOTLINE (OPTIONAL FOOTER)
%-------------------------------------------------------------------------------

% Footer template - displays optional logo at bottom center
% Logo height automatically defines the content margin
\setbeamertemplate{footline}{
  \begin{beamercolorbox}[wd=\paperwidth, center]{footline}
    \vskip\poster@bottommargin
    \ifx\@posterfooterlogo\@empty\else
      \@posterfooterlogo
      \vskip\poster@bottommargin
    \fi
  \end{beamercolorbox}
}

%-------------------------------------------------------------------------------
% POSTER-SPECIFIC FONT SIZES
%-------------------------------------------------------------------------------

% Larger font sizes for poster readability (scale with poster size)
% These work well for A0 at default scale

% Header typography
\setbeamerfont{poster headline}{size=\fontsize{78}{91}\selectfont, series=\bfseries}
\setbeamerfont{poster author}{size=\fontsize{46}{55}\selectfont}
\setbeamerfont{poster affiliation}{size=\fontsize{32}{38}\selectfont}
\setbeamerfont{poster email}{size=\fontsize{28}{34}\selectfont}
\setbeamerfont{poster qr label}{size=\fontsize{18}{22}\selectfont}

% Standard title metadata fonts mirror the poster header defaults.
\setbeamerfont{title}{parent=poster headline}
\setbeamerfont{author}{parent=poster author}
\setbeamerfont{institute}{parent=poster affiliation}
\setbeamerfont{email}{parent=poster email}

% Frame title (section headers in poster)
\setbeamerfont{frametitle}{size=\fontsize{64}{76}\selectfont, series=\bfseries}

% Block titles (regular, alert, example)
\setbeamerfont*{block title}{parent=poster author, series=\bfseries}
\setbeamerfont*{block title alerted}{parent=poster author, series=\bfseries}
\setbeamerfont*{block title example}{parent=poster author, series=\bfseries}

% Block body text (regular, alert, example)
\setbeamerfont{block body}{size=\fontsize{36}{43}\selectfont}
\setbeamerfont{block body alerted}{size=\fontsize{36}{43}\selectfont}
\setbeamerfont{block body example}{size=\fontsize{36}{43}\selectfont}

% Normal text (default body)
\setbeamerfont{normal text}{size=\fontsize{36}{43}\selectfont}

% Item labels (bullets)
\setbeamerfont{itemize/enumerate body}{size=\fontsize{36}{43}\selectfont}
\setbeamerfont{itemize/enumerate subbody}{size=\fontsize{32}{38}\selectfont}
\setbeamerfont{itemize/enumerate subsubbody}{size=\fontsize{28}{34}\selectfont}

% Caption text
\setbeamerfont{caption}{size=\fontsize{30}{36}\selectfont}
\setbeamerfont{caption name}{size=\fontsize{30}{36}\selectfont, series=\bfseries}

%-------------------------------------------------------------------------------
% POSTER-SPECIFIC COLORS
%-------------------------------------------------------------------------------

% Headline colors
\setbeamercolor{headline}{fg=IUCream, bg=IUDarkestCrimson}
\setbeamercolor{headline accent}{fg=white, bg=IULightCrimson}

% Ensure background is light cream (or can be overridden to white)
\setbeamercolor{background canvas}{bg=IULightCream}

% Optional: Override to pure white if preferred
% \setbeamercolor{background canvas}{bg=white}

%-------------------------------------------------------------------------------
% POSTER BLOCK CUSTOMIZATION
%-------------------------------------------------------------------------------

% Block body padding is a global poster length. Set it with
% \posterblockmargin{<length>}; horizontal and vertical insets use the same
% value for every block.
\newlength{\poster@blockcontentwidth}
\newlength{\poster@blockcontentpad}
\newcommand{\poster@computeblockcontentpad}{%
  \setlength{\poster@blockcontentpad}{\poster@blockmargin}%
  \setlength{\poster@blockcontentwidth}{\dimexpr\linewidth-2\poster@blockcontentpad\relax}%
  \ifdim\poster@blockcontentwidth<0pt
    \setlength{\poster@blockcontentwidth}{0pt}%
  \fi
}

\newcommand{\poster@blockbegin}[2]{%
  \begin{beamercolorbox}[rounded=false, shadow=false, center, sep=0pt]{#1}
    \usebeamerfont{#1}\strut\insertblocktitle\strut
  \end{beamercolorbox}
  \nointerlineskip
  \usebeamerfont{#2}%
  \begin{beamercolorbox}[rounded=false, shadow=false, sep=0pt, vmode]{#2}%
    \poster@computeblockcontentpad%
    \vspace{\poster@blockcontentpad}%
    \noindent\hspace{\poster@blockcontentpad}%
    \begin{minipage}{\poster@blockcontentwidth}%
      \ignorespaces
}

\newcommand{\poster@blockend}{%
      \unskip
    \end{minipage}%
    \par\vspace{\poster@blockcontentpad}%
  \end{beamercolorbox}%
  \vskip\postergutter
}

\setbeamertemplate{block begin}{\poster@blockbegin{block title}{block body}}
\setbeamertemplate{block end}{\poster@blockend}

% Alert block
\setbeamertemplate{block alerted begin}{\poster@blockbegin{block title alerted}{block body alerted}}
\setbeamertemplate{block alerted end}{\poster@blockend}

% Example block
\setbeamertemplate{block example begin}{\poster@blockbegin{block title example}{block body example}}
\setbeamertemplate{block example end}{\poster@blockend}

%-------------------------------------------------------------------------------
% ITEMIZE/ENUMERATE CUSTOMIZATION FOR POSTERS
%-------------------------------------------------------------------------------

% Larger bullet points
\setbeamertemplate{itemize item}{\color{IUCrimson}\raisebox{0.2ex}{\scalebox{1.8}{$\bullet$}}}
\setbeamertemplate{itemize subitem}{\color{IUDarkCrimson}\raisebox{0.2ex}{\scalebox{1.5}{$\circ$}}}
\setbeamertemplate{itemize subsubitem}{\color{IUDarkCrimson}\raisebox{0.2ex}{\scalebox{1.2}{$-$}}}

%-------------------------------------------------------------------------------
% HELPER COMMANDS FOR POSTER LAYOUT
%-------------------------------------------------------------------------------

% Command to create a section header (not a block, just styled text)
\newcommand{\postersection}[1]{%
  \vskip\dimexpr\postergutter/2\relax
  {\usebeamerfont{frametitle}\color{IUCrimson}\textbf{#1}}
  \vskip\dimexpr\postergutter/4\relax
  {\color{IULightCrimson}\rule{\linewidth}{\dimexpr3\postergutter/20\relax}}
  \vskip\dimexpr\postergutter/4\relax
}

% Fixed geometry grid. Rows and columns are proportional weights; gutters are
% subtracted before space is distributed. Each cell has a fixed width and height,
% so grids can be nested recursively inside cells.
\ExplSyntaxOn
\clist_new:N \l_poster_layout_rows_clist
\clist_new:N \l_poster_layout_cols_clist
\dim_new:N \l_poster_layout_grid_width_dim
\dim_new:N \l_poster_layout_grid_height_dim
\dim_new:N \l_poster_layout_available_height_dim
\dim_new:N \l_poster_layout_available_width_dim
\dim_new:N \l_poster_layout_current_row_height_dim
\dim_new:N \l_poster_layout_current_col_width_dim
\dim_new:N \l_poster_fillblock_title_height_dim
\dim_new:N \l_poster_fillblock_body_natural_height_dim
\fp_new:N \l_poster_layout_row_total_fp
\fp_new:N \l_poster_layout_col_total_fp
\int_new:N \l_poster_layout_row_count_int
\int_new:N \l_poster_layout_col_count_int
\int_new:N \l_poster_layout_row_index_int
\int_new:N \l_poster_layout_col_index_int
\tl_new:N \l_poster_layout_current_row_weight_tl
\tl_new:N \l_poster_layout_current_col_weight_tl
\tl_new:N \l_poster_fillblock_title_color_tl
\tl_new:N \l_poster_fillblock_body_color_tl

\NewDocumentEnvironment{posterlayoutgrid}{O{\posterlayoutheight} m}
  {\poster_layout_grid_begin:nn {#1} {#2}}
  {\poster_layout_grid_end:}

\NewDocumentCommand{\posterlayoutrow}{m +m}
  {\poster_layout_row:nn {#1} {#2}}

\NewDocumentCommand{\postercell}{+m}
  {\poster_layout_cell:n {#1}}

\cs_new_protected:Npn \poster_layout_grid_begin:nn #1 #2
  {
    \par\nointerlineskip\noindent
    \group_begin:
    \dim_set:Nn \l_poster_layout_grid_width_dim { \linewidth }
    \dim_set:Nn \l_poster_layout_grid_height_dim { #1 }
    \clist_set:Nn \l_poster_layout_rows_clist { #2 }
    \int_set:Nn \l_poster_layout_row_count_int
      { \clist_count:N \l_poster_layout_rows_clist }
    \dim_set:Nn \l_poster_layout_available_height_dim
      {
        \l_poster_layout_grid_height_dim
        - \int_eval:n { \l_poster_layout_row_count_int - 1 } \postergutter
      }
    \fp_zero:N \l_poster_layout_row_total_fp
    \clist_map_inline:Nn \l_poster_layout_rows_clist
      { \fp_add:Nn \l_poster_layout_row_total_fp {##1} }
    \int_zero:N \l_poster_layout_row_index_int
    \vbox to \dim_use:N \l_poster_layout_grid_height_dim \bgroup
      \offinterlineskip
      \ignorespaces
  }

\cs_new_protected:Npn \poster_layout_grid_end:
  {
      \unskip
    \egroup
    \par\ignorespacesafterend
    \group_end:
  }

\cs_new_protected:Npn \poster_layout_row:nn #1 #2
  {
    \int_incr:N \l_poster_layout_row_index_int
    \tl_set:Nx \l_poster_layout_current_row_weight_tl
      {
        \clist_item:Nn \l_poster_layout_rows_clist
          { \int_use:N \l_poster_layout_row_index_int }
      }
    \dim_set:Nn \l_poster_layout_current_row_height_dim
      {
        \fp_eval:n
          {
            ( \l_poster_layout_current_row_weight_tl )
            / ( \fp_use:N \l_poster_layout_row_total_fp )
          }
        \l_poster_layout_available_height_dim
      }
    \clist_set:Nn \l_poster_layout_cols_clist { #1 }
    \int_set:Nn \l_poster_layout_col_count_int
      { \clist_count:N \l_poster_layout_cols_clist }
    \dim_set:Nn \l_poster_layout_available_width_dim
      {
        \l_poster_layout_grid_width_dim
        - \int_eval:n { \l_poster_layout_col_count_int - 1 } \postergutter
      }
    \fp_zero:N \l_poster_layout_col_total_fp
    \clist_map_inline:Nn \l_poster_layout_cols_clist
      { \fp_add:Nn \l_poster_layout_col_total_fp {##1} }
    \int_zero:N \l_poster_layout_col_index_int
    \hbox to \dim_use:N \l_poster_layout_grid_width_dim \bgroup
      #2
    \egroup
    \int_compare:nNnT
      { \l_poster_layout_row_index_int } < { \l_poster_layout_row_count_int }
      { \vskip\postergutter }
  }

\cs_new_protected:Npn \poster_layout_cell:n #1
  {
    \int_incr:N \l_poster_layout_col_index_int
    \int_compare:nNnT { \l_poster_layout_col_index_int } > { 1 }
      { \hskip\postergutter }
    \tl_set:Nx \l_poster_layout_current_col_weight_tl
      {
        \clist_item:Nn \l_poster_layout_cols_clist
          { \int_use:N \l_poster_layout_col_index_int }
      }
    \dim_set:Nn \l_poster_layout_current_col_width_dim
      {
        \fp_eval:n
          {
            ( \l_poster_layout_current_col_weight_tl )
            / ( \fp_use:N \l_poster_layout_col_total_fp )
          }
        \l_poster_layout_available_width_dim
      }
    \begin{minipage}[t][\dim_use:N \l_poster_layout_current_row_height_dim][t]
      { \dim_use:N \l_poster_layout_current_col_width_dim }
      \raggedright
      \setlength{\poster@cellwidth}{\dim_use:N \l_poster_layout_current_col_width_dim}%
      \setlength{\poster@cellheight}{\dim_use:N \l_poster_layout_current_row_height_dim}%
      \poster@inlayoutcelltrue
      \renewcommand{\posterlayoutheight}{\poster@cellheight}%
      \ignorespaces
      #1
      \unskip
    \end{minipage}%
  }

\NewDocumentEnvironment{posterfillblock}{O{block} m +b}
  {\poster_fillblock:nnn {#1} {#2} {#3}}
  {}

\cs_new_protected:Npn \poster_fillblock_set_style:n #1
  {
    \str_case:nnF {#1}
      {
        {block}
          {
            \tl_set:Nn \l_poster_fillblock_title_color_tl { block~title }
            \tl_set:Nn \l_poster_fillblock_body_color_tl { block~body }
          }
        {alert}
          {
            \tl_set:Nn \l_poster_fillblock_title_color_tl { block~title~alerted }
            \tl_set:Nn \l_poster_fillblock_body_color_tl { block~body~alerted }
          }
        {alertblock}
          {
            \tl_set:Nn \l_poster_fillblock_title_color_tl { block~title~alerted }
            \tl_set:Nn \l_poster_fillblock_body_color_tl { block~body~alerted }
          }
        {example}
          {
            \tl_set:Nn \l_poster_fillblock_title_color_tl { block~title~example }
            \tl_set:Nn \l_poster_fillblock_body_color_tl { block~body~example }
          }
        {exampleblock}
          {
            \tl_set:Nn \l_poster_fillblock_title_color_tl { block~title~example }
            \tl_set:Nn \l_poster_fillblock_body_color_tl { block~body~example }
          }
      }
      {
        \PackageWarning{beamerthemeIUmetropolis-poster}
          {Unknown~posterfillblock~style~`#1'.~Using~regular~block}
        \tl_set:Nn \l_poster_fillblock_title_color_tl { block~title }
        \tl_set:Nn \l_poster_fillblock_body_color_tl { block~body }
      }
  }

\cs_new_protected:Npn \poster_fillblock:nnn #1 #2 #3
  {
    \poster_fillblock_set_style:n {#1}
    \ifposter@inlayoutcell
      \poster_fillblock_typeset:nn {#2} {#3}
    \else
      \PackageWarning{beamerthemeIUmetropolis-poster}
        {posterfillblock~`#2'~used~outside~a~postercell.~Falling~back~to~block}
      \begin{block}{#2}
        #3
      \end{block}
    \fi
  }

\cs_new_protected:Npn \poster_fillblock_typeset:nn #1 #2
  {
    \setbox\poster@fillblocktitlebox=\vbox
      {
        \hsize=\poster@cellwidth
        \begin{beamercolorbox}
          [wd=\poster@cellwidth, rounded=false, shadow=false, center, sep=0pt]
          { \tl_use:N \l_poster_fillblock_title_color_tl }
          \usebeamerfont{\tl_use:N \l_poster_fillblock_title_color_tl}%
          \strut #1\strut
        \end{beamercolorbox}
      }
    \dim_set:Nn \l_poster_fillblock_title_height_dim
      { \ht\poster@fillblocktitlebox + \dp\poster@fillblocktitlebox }
    \setlength{\poster@fillblockbodyheight}
      {
        \dimexpr\poster@cellheight
        - \dim_use:N \l_poster_fillblock_title_height_dim\relax
      }
    \ifdim\poster@fillblockbodyheight<0pt
      \PackageWarning{beamerthemeIUmetropolis-poster}
        {posterfillblock~`#1'~has~no~body~height.~Increase~the~cell~height}
      \setlength{\poster@fillblockbodyheight}{0pt}%
    \fi
    \begingroup
      \setlength{\linewidth}{\poster@cellwidth}%
      \poster@computeblockcontentpad
      \setlength{\poster@fillblockcontentheight}
        {\dimexpr\poster@fillblockbodyheight-2\poster@blockcontentpad\relax}%
      \ifdim\poster@fillblockcontentheight<0pt
        \setlength{\poster@fillblockcontentheight}{0pt}%
      \fi
      \setbox\poster@fillblockbodybox=\vbox
        {
          \hsize=\poster@blockcontentwidth
          \begin{minipage}[t]{\poster@blockcontentwidth}
            \usebeamerfont{\tl_use:N \l_poster_fillblock_body_color_tl}%
            \ignorespaces #2\unskip
          \end{minipage}
        }
      \dim_set:Nn \l_poster_fillblock_body_natural_height_dim
        { \ht\poster@fillblockbodybox + \dp\poster@fillblockbodybox }
      \ifdim\dim_use:N \l_poster_fillblock_body_natural_height_dim>\poster@fillblockcontentheight
        \PackageWarning{beamerthemeIUmetropolis-poster}
          {Content~in~posterfillblock~`#1'~exceeds~its~assigned~cell~height.~
           Reduce~content,~font~size,~image~scale,~or~change~row~proportions}
      \fi
      \ifdim\dim_use:N \l_poster_fillblock_body_natural_height_dim<\poster@fillblockcontentheight
        \PackageWarning{beamerthemeIUmetropolis-poster}
          {Content~in~posterfillblock~`#1'~underfills~its~assigned~cell~height.~
           Increase~content,~image~scale,~font~size,~or~change~row~proportions}
      \fi
      \box\poster@fillblocktitlebox
      \nointerlineskip
      \begin{beamercolorbox}
        [wd=\poster@cellwidth, ht=\poster@fillblockbodyheight, dp=0pt,
         rounded=false, shadow=false, sep=0pt, vmode]
        { \tl_use:N \l_poster_fillblock_body_color_tl }
        \vbox to \poster@fillblockbodyheight
          {
            \vskip\poster@blockcontentpad
            \noindent\hbox to \poster@cellwidth
              {
                \hskip\poster@blockcontentpad
                \vbox to \poster@fillblockcontentheight
                  {
                    \unvbox\poster@fillblockbodybox
                    \vfil
                  }
                \hfil
              }
            \vskip\poster@blockcontentpad
          }
      \end{beamercolorbox}
    \endgroup
  }
\ExplSyntaxOff

% Command for figure with caption
\newcommand{\posterfigure}[3][1.0]{%
  \par
  \begingroup
    \setlength{\poster@figurewidth}{\dimexpr\linewidth-2\poster@blockmargin\relax}%
    \ifdim\poster@figurewidth<1pt
      \setlength{\poster@figurewidth}{\linewidth}%
    \fi
    \centering
    \includegraphics[width=#1\poster@figurewidth]{#2}%
    \par\vskip\dimexpr\postergutter/4\relax
    \parbox{\poster@figurewidth}{\centering\usebeamerfont{caption}\color{IUBlack}#3}%
    \par
  \endgroup
}

